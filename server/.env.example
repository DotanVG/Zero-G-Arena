# Render injects PORT automatically; do not set manually.

NODE_ENV=production

# Allowlisted browser origin(s). Comma-separated for multiple Vercel domains.
# Defaults already include https://orbital-breach.vercel.app and localhost dev origins.
CLIENT_ORIGIN=https://orbital-breach.vercel.app

# Public hostname Colyseus advertises in seat reservations (no protocol).
# Optional; falls back to request Host header on Render.
PUBLIC_ADDRESS=orbital-breach-server.onrender.com
